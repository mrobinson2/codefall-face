# Codefall Face backend configuration.
# Copy to .env (and `export $(cat .env | xargs)` or use your process manager),
# or set these directly in your host's environment.
# EVERYTHING here is optional — without it the app runs on local Web Speech.

# ---- Azure Voice Live (primary voice provider) ----
# Your Azure AI Foundry / Cognitive Services resource endpoint:
AZURE_VOICE_LIVE_ENDPOINT=https://YOUR-RESOURCE.cognitiveservices.azure.com
AZURE_VOICE_LIVE_KEY=your-key-here
# Model to bind the realtime session to:
AZURE_VOICE_LIVE_MODEL=gpt-4o
AZURE_VOICE_LIVE_API_VERSION=2025-05-01-preview

# ---- Lacy.ai (fallback provider) ----
#LACY_API_KEY=your-lacy-key
#LACY_BASE=https://app.lacy.ai/api
#LACY_REPLY_PATH=/user/ai/reply

# ---- server ----
PORT=8787
